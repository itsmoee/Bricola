{
  "expo": {
    "name": "Bricola",
    "slug": "bricola-native",
    "version": "1.0.0",
    "orientation": "portrait",
    "android": {
      "package": "bricola.app",
      "permissions": [
        "INTERNET",
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "WAKE_LOCK",
        "RECEIVE_BOOT_COMPLETED",
        "ACCESS_NETWORK_STATE",
        "POST_NOTIFICATIONS"
      ]
    },
    "plugins": ["expo-notifications", "expo-location", "expo-image-picker"]
  }
}
