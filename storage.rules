rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // Helper: doc ID format is {uid}_{ROLE} — check ownership by uid prefix
    function isMyPath(pathUserId) {
      return request.auth != null &&
        pathUserId.matches(request.auth.uid + '_.*');
    }

    function isImage() {
      return request.resource.contentType.matches('image/.*');
    }

    function isPdf() {
      return request.resource.contentType == 'application/pdf';
    }

    // ─── tech_docs/{userId}/...  ─────────────────────────────────────────────
    // CV, ID card photos, gallery images uploaded by technicians
    match /tech_docs/{userId}/{allPaths=**} {
      // Only the owning technician can upload; max 10 MB; images or PDF only
      allow write: if isMyPath(userId) &&
        request.resource.size < 10 * 1024 * 1024 &&
        (isImage() || isPdf());

      // Owner can always read their own files
      // Other authenticated users can read (admins need to review CVs/IDs)
      allow read: if request.auth != null;
    }

    // ─── request_photos/{requestId}/...  ─────────────────────────────────────
    // Photos attached to service requests
    match /request_photos/{requestId}/{allPaths=**} {
      // Any authenticated user may upload request photos; max 5 MB; images only
      allow write: if request.auth != null &&
        request.resource.size < 5 * 1024 * 1024 &&
        isImage();

      allow read: if request.auth != null;
    }

    // ─── profile_pictures/{userId}/...  ──────────────────────────────────────
    match /profile_pictures/{userId}/{allPaths=**} {
      // Only the owner can upload their profile picture; max 5 MB; images only
      allow write: if isMyPath(userId) &&
        request.resource.size < 5 * 1024 * 1024 &&
        isImage();

      allow read: if request.auth != null;
    }
  }
}
